# Copy this file to .env and fill in what you need.
# None of these are required for the site to run locally.

# --- Draft generator (scripts/draft-from-feeds.mjs) ---
# Required only when you actually generate drafts.
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-sonnet-4-5.
MODEL=claude-sonnet-4-5
# Optional. Defaults to 3.
MAX_PER_RUN=3

# --- Newsletter form (src/components/NewsletterForm.astro) ---
# Set to "beehiiv", "substack-iframe", or leave as "stub" (default).
PUBLIC_NEWSLETTER_PROVIDER=stub
# Beehiiv: https://embeds.beehiiv.com/<id>
PUBLIC_NEWSLETTER_ACTION_URL=

# --- Google AdSense (src/layouts/BaseLayout.astro) ---
# Looks like ca-pub-1234567890123456. Leave blank to disable.
PUBLIC_ADSENSE_CLIENT_ID=
