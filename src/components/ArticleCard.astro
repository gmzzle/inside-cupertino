---
const { article, featured = false } = Astro.props as {
  article: {
    slug: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      tags: string[];
      heroImage?: string;
      heroAlt?: string;
    };
  };
  featured?: boolean;
};

const dateLabel = new Intl.DateTimeFormat('en', { dateStyle: 'medium' }).format(article.data.pubDate);
const primaryTag = article.data.tags[0] ?? 'Apple';
---

<article class="group">
  <a href={`/articles/${article.slug}/`} class="block">
    <div class:list={['flex gap-6 md:gap-8', featured ? 'flex-col' : 'flex-col md:flex-row']}>
      {article.data.heroImage && (
        <div class:list={[
          'overflow-hidden bg-surface-container-low',
          featured ? 'w-full aspect-[16/9]' : 'w-full md:w-1/3 aspect-[4/3] flex-shrink-0'
        ]}>
          <img
            src={article.data.heroImage}
            alt={article.data.heroAlt ?? ''}
            loading="lazy"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
          />
        </div>
      )}
      <div class="flex-1">
        <div class="flex items-center gap-4 mb-3">
          <span class="text-[10px] font-label uppercase tracking-widest text-primary">{primaryTag}</span>
          <span class="text-outline text-[10px]">{dateLabel}</span>
        </div>
        <h3 class:list={[
          'font-serif text-on-surface mb-3 group-hover:text-primary transition-colors leading-tight',
          featured ? 'text-3xl md:text-4xl' : 'text-2xl md:text-3xl'
        ]}>{article.data.title}</h3>
        <p class="text-on-surface-variant leading-relaxed text-sm">{article.data.description}</p>
      </div>
    </div>
  </a>
</article>
